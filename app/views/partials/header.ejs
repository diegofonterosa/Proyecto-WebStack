<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo || 'Tienda Online' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-container">
      <div class="navbar-brand">
        <a href="/">TIENDA ONLINE</a>
      </div>

      <div class="navbar-menu">
        <form action="/search" method="GET" class="navbar-search">
          <input type="text" name="q" placeholder="Buscar productos..." required>
          <button type="submit">Buscar</button>
        </form>

        <div class="navbar-links">
          <a href="/">Inicio</a>
          <a href="/carrito" class="carrito-btn">
            Carrito
            <span id="nav-cart-count" class="carrito-count" style="display:none;">0</span>
          </a>
          <a href="/login" id="nav-login-link">Login</a>
          <a href="/register" id="nav-register-link">Registrarse</a>
          <a href="#" id="nav-logout-link" style="display:none;">Cerrar sesion</a>
          <div class="dropdown">
            <button class="dropbtn">Categorias</button>
            <div class="dropdown-content">
              <% (categorias || []).forEach((cat) => { %>
                <a href="/categoria?c=<%= encodeURIComponent(cat) %>"><%= cat %></a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="container">
  <script>
    (function () {
      const token = localStorage.getItem('token');
      const loginLink = document.getElementById('nav-login-link');
      const registerLink = document.getElementById('nav-register-link');
      const logoutLink = document.getElementById('nav-logout-link');
      const cartCount = document.getElementById('nav-cart-count');

      const setCartCount = function (count) {
        if (!cartCount) {
          return;
        }

        const safeCount = Number.isFinite(count) ? Math.max(0, count) : 0;
        if (safeCount > 0) {
          cartCount.textContent = safeCount > 99 ? '99+' : String(safeCount);
          cartCount.style.display = 'flex';
          cartCount.classList.remove('cart-bump');
          void cartCount.offsetWidth;
          cartCount.classList.add('cart-bump');
          return;
        }

        cartCount.textContent = '0';
        cartCount.style.display = 'none';
      };

      const refreshCartCount = async function () {
        if (!token) {
          setCartCount(0);
          return;
        }

        try {
          const response = await fetch('/api/carrito', {
            headers: { Authorization: `Bearer ${token}` }
          });

          if (!response.ok) {
            setCartCount(0);
            return;
          }

          const data = await response.json();
          const items = Array.isArray(data.items) ? data.items : [];
          const totalItems = items.reduce(function (sum, item) {
            return sum + (Number(item.cantidad) || 0);
          }, 0);

          setCartCount(totalItems);
        } catch {
          setCartCount(0);
        }
      };

      window.refreshCartCount = refreshCartCount;

      if (token) {
        if (loginLink) loginLink.style.display = 'none';
        if (registerLink) registerLink.style.display = 'none';
        if (logoutLink) logoutLink.style.display = '';
      }

      refreshCartCount();

      if (logoutLink) {
        logoutLink.addEventListener('click', function (event) {
          event.preventDefault();
          localStorage.removeItem('token');
          setCartCount(0);
          window.location.href = '/';
        });
      }
    })();
  </script>
