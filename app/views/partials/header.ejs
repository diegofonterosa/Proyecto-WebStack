<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo || 'Tienda Online' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-container">
      <div class="navbar-brand">
        <a href="/">TIENDA ONLINE</a>
      </div>

      <div class="navbar-menu">
        <form action="/api/productos/search" method="GET" class="navbar-search">
          <input type="text" name="q" placeholder="Buscar productos..." required>
          <button type="submit">Buscar</button>
        </form>

        <div class="navbar-links">
          <a href="/">Inicio</a>
          <a href="/register">Registrarse</a>
          <div class="dropdown">
            <button class="dropbtn">Categorias</button>
            <div class="dropdown-content">
              <% (categorias || []).forEach((cat) => { %>
                <a href="/api/productos/search?categoria=<%= encodeURIComponent(cat) %>"><%= cat %></a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="container">
