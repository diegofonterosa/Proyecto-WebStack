# ============================================================
#  .env.example — Proyecto-WebStack
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env al repositorio (ya está en .gitignore).
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia_esto_root
MYSQL_DATABASE=tienda_db
MYSQL_USER=tienda_user
MYSQL_PASSWORD=cambia_esto_password

# ── JWT (misma clave usada en gateway, auth, order y Strapi) ─
# Genera un valor seguro con:  openssl rand -hex 32
JWT_SECRET=cambia_esto_jwt_secret_minimo_32_chars

# ── Strapi CMS ───────────────────────────────────────────────
# Contraseña del usuario strapi_user en MySQL
STRAPI_DB_PASSWORD=cambia_esto_strapi_password

# Secret para tokens de admin del panel Strapi
# Genera con:  openssl rand -hex 32
STRAPI_ADMIN_JWT_SECRET=cambia_esto_admin_jwt_secret_minimo_32_chars

# API Keys de Strapi (lista separada por comas de 4 valores base64)
# Genera con:  node -e "console.log([1,2,3,4].map(()=>require('crypto').randomBytes(16).toString('base64')).join(','))"
STRAPI_APP_KEYS=key1_base64,key2_base64,key3_base64,key4_base64
