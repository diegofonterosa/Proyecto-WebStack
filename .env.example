# Variables de Environment
# Copiar este archivo a .env y configurar según sea necesario

# Base de Datos
DB_HOST=db
DB_NAME=tienda_db
DB_USER=tienda_user
DB_PASS=tienda_pass123
DB_PORT=3306

# Aplicación
APP_NAME=Tienda Online
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Seguridad
SESSION_TIMEOUT=3600
SECURE_COOKIES=false

# Email (para notificaciones)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tu-email@gmail.com
MAIL_PASS=tu-contraseña

# Logs
LOG_LEVEL=debug
